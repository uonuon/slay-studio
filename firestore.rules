rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /services/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /config/{doc}   { allow read: if true; allow write: if request.auth != null; }
    match /slots/{doc}    { allow read, create: if true; allow update, delete: if request.auth != null; }
    match /bookings/{doc} { allow create: if true; allow read, update, delete: if request.auth != null; }
  }
}
